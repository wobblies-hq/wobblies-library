{
  "name": "@wobblies/library",
  "version": "1.0.0",
  "description": "Public wobblies examples catalog and CLI.",
  "type": "module",
  "bin": {
    "wobbly": "./dist/bin.js"
  },
  "files": [
    "dist",
    "examples.json",
    "wobblies",
    "docs",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "generate:examples": "bun scripts/generate-examples.ts",
    "validate:examples": "bun scripts/validate-examples.ts",
    "build": "bun run --bun zshy && chmod +x dist/bin.js",
    "smoke:wobbly": "bun scripts/smoke-wobbly-bin.ts",
    "prepack": "bun run build"
  },
  "dependencies": {
    "yaml": "^2.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.2.22",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14",
    "zshy": "^0.4.3"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/universe-backwards/wobblies-library.git"
  },
  "bugs": {
    "url": "https://github.com/universe-backwards/wobblies-library/issues"
  },
  "homepage": "https://github.com/universe-backwards/wobblies-library#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./examples": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./examples.json": "./dist/examples.json"
  },
  "zshy": {
    "exports": {
      ".": "./index.ts",
      "./examples": "./index.ts",
      "./examples.json": "./examples.json",
      "./package.json": "./package.json"
    },
    "bin": {
      "wobbly": "./bin.ts"
    },
    "cjs": false
  },
  "module": "./dist/index.js"
}
